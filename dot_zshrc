
# -------------------------------------------------------------
# Linux/GNU Specific Configuration
# -------------------------------------------------------------
export PATH="/usr/local/bin:/usr/bin:/bin:/usr/local/games:/usr/games:$HOME/.local/bin:$HOME/.atuin/bin:$HOME/go/bin:$PATH"

test -r "$HOME/.dircolors" && eval "$(dircolors -b "$HOME/.dircolors")"
alias ls='ls --color=auto'


# -------------------------------------------------------------
# WSL Specific Configuration
# -------------------------------------------------------------
export BROWSER="wslview"

zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"

if [ -f "$HOME/.zshrc_ext" ]; then
    . "$HOME/.zshrc_ext"
fi

case $- in
    *i*) ;;
    *) return;;
esac

