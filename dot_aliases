# ------------------------------ aliases -----------------------------

# linux cmds
alias mkdir='mkdir -p'
alias cp='cp -i'
alias mv='mv -i'
alias used="du -sh"
alias chmox='chmod +x'
alias aptup='sudo apt update'
alias aptupg="sudo apt update && sudo apt upgrade"
alias src='exec zsh -l'     # reload zsh
alias bash='exec bash -l'     # reload bash
alias info="sed -n '2p'"
alias cz="chezmoi"
alias czpush="chezmoi cd && chezmoi add -A . && chezmoi commit -m 'update dotfiles'"
alias pushtags="git push origin --tags"
alias grem="git remote -v"
alias nv='nvim'
alias grep='grep --color=auto'
# setup for syncing dot files to and from multiple computers
alias config='/usr/bin/git --git-dir=$HOME/.cfg --work-tree=$HOME' 

# search
alias gs="goog"   
alias ws="websearch" 

# mods charmbracelet - open ai
alias modsls='mods --list'
alias modsh='mods --show'
alias srcz="source ~/.zshrc"
alias srcb="source ~/.bashrc"

# commonly used directories
alias start='cd $STARTANEW'
alias scripts='cd $SCRIPTS'
alias snippets='cd $SNIPPETS'
alias got='cd $STARTANEW/gotools'
alias gith='cd $GHREPOS'
alias gitrv='git remote -v'
alias saved='cd $STARTANEW/saved'
alias notes='cd $STARTANEW/writing/notes'
alias l2c='cd $GHREPOS/learn2code'
alias pwri='cd $GHREPOS/power-installer'
alias vnotes='vim $STARTANEW/software/vim.md'
alias nvdir='cd $HOME/.config/nvim'
alias vimc='vim ~/.vim/vimrc'
alias cloneins='git clone -c http.sslVerify=false'

# gist related
alias gistc='gh gist create -'
alias gistls='gh gist list'
alias gisthelp='glow $STARTANEW/docs/gists-help.md'

# editing config files
alias hl='highlight -O ansi'

# git
alias status="git status"
alias gita="git add -A ."
alias gitc="git commit -m"
alias gitac="git add -A . && git commit -m"
alias gitcmt="git add -A . && git commit -m 'updated'"
alias gitp="git push origin main && echo 'pushing main to origin'"

#tmux
alias tlw="tmux list-windows"
alias tls="tmux ls"
alias tnew="tmux new -s"
alias win="tmux display-message -p '#W'"
alias srcall='current_pane=$(tmux display-message -p "#D"); tmux list-panes -a -F "#D" | grep -v "$current_pane" | xargs -I {} tmux send-keys -t {} "source ~/.zshrc" C-m; source ~/.zshrc'
alias attach="tmux a -t"
alias tkill="tmux kill-server"
alias tsrc="tmux source-file ~/.config/tmux/tmux.conf"

#useful
alias ytmp3="noglob yt-dlp -x --audio-format mp3"
alias ytget="no globyt-dlp"
alias ytg='noglob ytt'
alias entrgo='ls *.go | entr -r go run main.go'

#ai
alias oll='ollama run llama3.2:latest'
alias ol="ollama run llama3"

# open the last modified file in a directory
alias vlast="vim $STARTANEW/lastcmd"

# save last cli cmd to file
alias savelast='atuin history last -f {command} > $STARTANEW/lastcmd'

# cat the last saved buffer
alias catbuf='cat $STARTANEW/saved/buf'
alias copykey='ssh-copy-id -i ~/.ssh/id_ed25519.pub'

