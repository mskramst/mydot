#!/bin/zsh
#  ----------------------------- setup -------------------------------
# cut and move to to .bashrc to load this file
# if [ -f ~/.zshrc_ext ]; then
#   . ~/.zshrc_ext
# fi

# Source common shell configurations
if [ -f "$HOME/.common_shell_config" ]; then
    source "$HOME/.common_shell_config"
fi


# --------------------- Binary Picker based on OS --------------------
# Detect OS once at shell startup
export OS_TYPE=$(uname -s | tr '[:upper:]' '[:lower:]')

# Helper function to run the correct binary
run_go_tool() {
    local tool_name=$1
    shift
    local bin_path="$HOME/scripts/.bin/${tool_name}_${OS_TYPE}"

    if [[ -f "$bin_path" ]]; then
        "$bin_path" "$@"
    else
        echo "Error: Binary for $tool_name not found at $bin_path"
        return 1
    fi
}

# uses different binary depending on OS
snip() { run_go_tool "snip" "$@" }
gp()   { run_go_tool "gp" "$@" }

# ------------------------------- colors -------------------------------

[ -n "${TMUX}" ] && winidx=$(tmux display-message -p '#I')

if (( winidx <0)); then
  winidx=""
fi

# This command takes your .dircolors file and 
# turns it into the LS_COLORS variable automatically
# # Determine which dircolors command to use
if command -v dircolors >/dev/null 2>&1; then
  DIR_COLORS_CMD="dircolors"
elif command -v gdircolors >/dev/null 2>&1; then
  DIR_COLORS_CMD="gdircolors"
fi

# If a command was found and the config file exists, run it
if [[ -n "$DIR_COLORS_CMD" && -f "$HOME/.dircolors" ]]; then
  eval "$($DIR_COLORS_CMD -b "$HOME/.dircolors")"
fi

# ------------------------------ prompt (ZSH-specific) ------------------------------

autoload -Uz vcs_info
zstyle ':vcs_info:*' enable git svn
# This line obtains information from the vcs.
zstyle ':vcs_info:git*' formats "- (%F{red}%b%f) "
precmd() {
    vcs_info
}

# Enable substitution in the prompt.
setopt prompt_subst

# Config for the prompt. PS1 synonym.
#precmd() { print -P "\n%F{yellow}%1~%f/" }
#prompt='%F{yellow}%1/%f ${vcs_info_msg_0_}> '
#precmd() { print -P "\n%F{yellow}%1~%f/" }
#BRIGHT_WHITE='\e[97m'

# Config for the prompt. PS1 synonym.
#nPROMPT="  $winidx%F{white}(%n)%f %F{$BRIGHT_WHITE}%f%F{red}${vcs_info_msg_0_}%f --> %F{blue}%f "
precmd() {
    vcs_info
		print -P
    print -P '%B%1~/%b ${vcs_info_msg_0_}%f'
}

