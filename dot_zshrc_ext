#!/bin/zsh
#
if [ -f "$HOME/.aliases" ]; then
   source "$HOME/.aliases"
fi


# ------------------------------- colors -------------------------------
# Initialize the variable as empty by default
winidx=""

# Only query tmux if the TMUX environment variable actually exists
if [[ -n "$TMUX" ]]; then
  winidx=$(tmux display-message -p '#I')
fi

# (Optional) If you want to format it to display inside your prompt string:
# For example, if winidx is 1, this turns it into "[1] "
if [[ -n "$winidx" ]]; then
  TMUX_PROMPT_PREFIX="[$winidx] "
else
  TMUX_PROMPT_PREFIX=""
fi
[ -n "${TMUX}" ] && winidx=$(tmux display-message -p '#I')

# ----------------------------- Atuin Up-Arrow Binding -----------------------
if command -v atuin &> /dev/null; then
    # Initialize Atuin's Zsh hooks first
    eval "$(atuin init zsh)"

    # Bind the Up Arrow key to trigger the Atuin history widget
    bindkey '^[[A' atuin-up-search
    bindkey '^[OA' atuin-up-search
fi
# -------------------------- Loads functions -------------------------

# 1. Define the functions directory
local my_func_dir="$HOME/.zsh/functions"

# 2. Add it to fpath
fpath=("$my_func_dir" $fpath)

# 3. Autoload all files inside that directory dynamically
if [ -d "$my_func_dir" ]; then
    for func in "$my_func_dir"/*(N:.); do
        autoload -Uz "${func:t}"
    done
fi


# ------------------------------ prompt (ZSH-specific) ---------------

# Load version control info library
autoload -Uz vcs_info

# Enable git (removed svn to speed up directory loading)
zstyle ':vcs_info:*' enable git

# Format git branch display (red branch name in parentheses)
zstyle ':vcs_info:git*' formats "- (%F{red}%b%f) "

# Ensure vcs_info updates before every prompt display
precmd() {
    vcs_info
}

# Enable parameter substitution in the prompt
setopt prompt_subst

# A clean two-line prompt
PROMPT='
%B%1~/%b ${vcs_info_msg_0_}%f
$winidx %B%(!.#.)%b --> '

# ------------------------ environmental variables -------------------------------
export TEMPLATES="$HOME/Templates"
export USER="${USER:-$(whoami)}"
export GITUSER="mskramst"
export REPOS="$HOME/repos"
export GHREPOS="$REPOS/github.com/$GITUSER"
export STARTANEW="$GHREPOS/startanew"
export SNIPPETS="$STARTANEW/snippets"
export SCRIPTS="$STARTANEW/scripts"
export PSCRIPTS="$HOME/scripts"
export NOTES="$STARTANEW/writing/notes"
export TODODIR="$STARTANEW/todo"
export BACKUPDIR="$STARTANEW/backup"
export DESKTOP="$HOME/Desktop"
export DOCUMENTS="$HOME/Documents"
export DOWNLOADS="$HOME/Downloads"
export PICTURES="$HOME/Pictures"
export HRULEWIDTH=73
export EDITOR=vim
export EDITOR_PREFIX=vim
export VISUAL=vim
export TERM=xterm-256color # Consider if this is universally desired for both shells

export GOPRIVATE="github.com/$GITUSER"
export GOPATH="$HOME/go"      
export GOBIN="$HOME/.local/bin"

# Update PATH (common logic)
base_path="$STARTANEW/scripts"
dirs=("dev" "coding" "gpt" "js" "java" "")
for dir in "${dirs[@]}"; do
    export PATH=$PATH:$base_path/$dir
done

GO_TOOL_BIN="$STARTANEW/scripts/.bin"

if [ -d "$GO_TOOL_BIN" ] && [[ ":$PATH:" != *":$GO_TOOL_BIN:"* ]]; then
    export PATH="$GO_TOOL_BIN:$PATH"
fi

# -------------------------- color man pages -------------------------
# Using the more comprehensive set from bashrc_ext, which should work in ZSH too
export LESS="-R"
export LESS_TERMCAP_mb=$'\e[1;31m'     # begin bold
export LESS_TERMCAP_md=$'\e[1;33m'     # begin blink
export LESS_TERMCAP_so=$'\e[01;44;37m' # begin reverse video
export LESS_TERMCAP_us=$'\e[01;37m'    # begin underline
export LESS_TERMCAP_me=$'\e[0m'        # reset bold/blink
export LESS_TERMCAP_se=$'\e[0m'        # reset reverse video
export LESS_TERMCAP_ue=$'\e[0m'        # reset underline
export GROFF_NO_SGR=1                  # for konsole and gnome-terminal

# ----------------------------- history -------------------------------
# Common history settings
set -o vi
HISTCONTROL=ignoreboth
HISTSIZE=5000
HISTFILESIZE=10000

# ------------------------------- PATH & CDPATH -------------------------------

# 1. Tell Zsh to keep these arrays unique (removes duplicates automatically)
typeset -U path cdpath

# 2. Add to PATH (replaces pathappend)
# Just add to the array; Zsh handles the colons and existence checks if you want
[[ -d "$HOME/scripts" ]] && path+=("$HOME/scripts")

# 3. Configure CDPATH
# This allows you to 'cd' into these folders from anywhere
cdpath=(
  .
  ~/repos/github.com
  ~/repos/github.com/$USER
  ~/repos/github.com/$USER/startanew
  ~/repos
  ~
)

export PATH CDPATH

[ -n "${TMUX}" ] && winidx=$(tmux display-message -p '#I')
if (( winidx <0)); then
  winidx=""
fi

