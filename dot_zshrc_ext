#!/bin/zsh
#  ----------------------------- setup -------------------------------
# cut and move to to .bashrc to load this file
# if [ -f ~/.zshrc_ext ]; then
#   . ~/.zshrc_ext
# fi

# Source common shell configurations
if [ -f "$HOME/.common_shell_config" ]; then
    source "$HOME/.common_shell_config"
fi


#--------------------- Binary Picker based on OS --------------------
# Detect OS once at shell startup
export OS_TYPE=$(uname -s | tr '[:upper:]' '[:lower:]')
ARCH_TYPE=$(uname -m | sed 's/x86_64/amd64/') 

# Helper function to run the correct binary
run_go_tool() {
    local tool_name=$1
    shift
    local bin_path="$SCRIPTS/.bin/${tool_name}_${OS_TYPE}_${ARCH_TYPE}"

    if [[ -f "$bin_path" ]]; then
        "$bin_path" "$@"
    else
        echo "Error: Binary for $tool_name not found at $bin_path"
        return 1
    fi
}

# uses different binary depending on OS
snip() { run_go_tool "snip" "$@" }
gp()   { run_go_tool "gp" "$@" }
32bits()   { run_go_tool "32bits" "$@" }
secure()   { run_go_tool "secure" "$@" }
reveal()   { run_go_tool "reveal" "$@" }

# ------------------------------- colors -------------------------------

[ -n "${TMUX}" ] && winidx=$(tmux display-message -p '#I')

if (( winidx <0)); then
  winidx=""
fi

# This command takes your .dircolors file and 
# turns it into the LS_COLORS variable automatically
if [[ -f ~/.dircolors ]]; then
  test -r "$HOME/.dircolors" && eval $(dircolors -b "$HOME/.dircolors")
fi

# -------------------------- Loads functions -------------------------

# 1. Define the functions directory
local my_func_dir="$HOME/.zsh/functions"

# 2. Add it to fpath
fpath=("$my_func_dir" $fpath)

# 3. Autoload all files inside that directory dynamically
if [ -d "$my_func_dir" ]; then
    for func in "$my_func_dir"/*(N:.); do
        autoload -Uz "${func:t}"
    done
fi


# ------------------------------ prompt (ZSH-specific) ---------------

# Load version control info library
autoload -Uz vcs_info

# Enable git (removed svn to speed up directory loading)
zstyle ':vcs_info:*' enable git

# Format git branch display (red branch name in parentheses)
zstyle ':vcs_info:git*' formats "- (%F{red}%b%f) "

# Ensure vcs_info updates before every prompt display
precmd() {
    vcs_info
}

# Enable parameter substitution in the prompt
setopt prompt_subst

# A clean two-line prompt
PROMPT='
%B%1~/%b ${vcs_info_msg_0_}%f
$winidx %B%(!.#.)%b --> '

